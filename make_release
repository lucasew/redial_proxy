#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
	echo "./make_release <patch|minor|major|x.y.z>" >&2
	exit 1
fi

VERSION="$1"
mapfile -t CURRENT_VERSION < <(tr '.' '\n' <version.txt)

case "$VERSION" in
patch)
	VERSION="${CURRENT_VERSION[0]}.${CURRENT_VERSION[1]}.$((CURRENT_VERSION[2] + 1))"
	;;
minor)
	VERSION="${CURRENT_VERSION[0]}.$((CURRENT_VERSION[1] + 1)).0"
	;;
major)
	VERSION="$((CURRENT_VERSION[0] + 1)).0.0"
	;;
*)
	# allow explicit semver; light validation
	if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
		echo "invalid version: $VERSION (want patch|minor|major|x.y.z)" >&2
		exit 1
	fi
	;;
esac

printf '%s' "$VERSION" >version.txt

# Only stage the version file — never sweep unrelated dirty files into a release commit.
git add version.txt
git commit -sm "bump to $VERSION"
if [[ ! -v NO_TAG ]]; then
	git tag "$VERSION"
	# Push only this tag (git accepts --tag as unambiguous prefix of --tags, but be explicit).
	git push origin "refs/tags/${VERSION}"
fi
git push
